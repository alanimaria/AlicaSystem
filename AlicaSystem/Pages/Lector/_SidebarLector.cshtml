@{
    string activo = ViewData["Activo"] as string ?? "";
}
<aside class="sidebar">
    <div class="brand">
        <img src="~/images/logo.png" alt="Alica System" style="width:40px;height:40px;object-fit:contain;">
        <div class="brand-text">
            <div class="name">Alica System</div>
            <div class="sub">Sistema Bibliotecario</div>
        </div>
    </div>

    <nav class="nav-group">
        <div class="nav-group-label">Lector</div>
        <a class="nav-item @(activo == "Dashboard" ? "active" : "")" href="/Lector/Dashboard"><span class="dot"></span>Menú principal</a>
        <a class="nav-item @(activo == "Catalogo" ? "active" : "")" href="/Lector/Catalogo"><span class="dot"></span>Catálogo y Consultas</a>
        <a class="nav-item @(activo == "MisPrestamos" ? "active" : "")" href="/Lector/MisPrestamos"><span class="dot"></span>Mis préstamos</a>
        <a class="nav-item @(activo == "MisReservas" ? "active" : "")" href="/Lector/MisReservas"><span class="dot"></span>Mis reservas</a>
        <a class="nav-item @(activo == "MisListas" ? "active" : "")" href="/Lector/MisListas"><span class="dot"></span>Mis listas</a>
    </nav>

    <div class="sidebar-foot">Alica System · Universidad · Desarrollo Web II</div>
</aside>