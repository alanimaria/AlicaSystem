@page
@model AlicaSystem.Pages.Lector.MisListasModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Alica System - Mis listas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/alica.css">
</head>
<body>
    <div class="app">
        <partial name="_SidebarLector" view-data="ViewData" />
        <main class="stage" style="padding:32px;">

            <div class="screen-title">
                <span class="eyebrow">Lector · Listas</span>
                <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;">
                    <h1>Mis listas</h1>
                    <a class="btn btn-primary" href="/Lector/NuevaLista"><i class="bi bi-plus-lg"></i> Nueva lista</a>
                </div>
            </div>

            <form method="get" class="search-bar" style="margin-bottom:20px;">
                <input class="field" type="text" name="busqueda" value="@Model.Busqueda" placeholder="Buscar lista por nombre...">
                <button class="btn btn-ghost" type="submit"><i class="bi bi-search"></i></button>
            </form>

            @if (TempData["Mensaje"] != null)
            {
                <p>@TempData["Mensaje"]</p>
            }

            <div class="grid-3">
                @foreach (var l in Model.Listas)
                {
                    <div class="card pad-m" style="position:relative;">
                        <div class="section-head">
                            <h3 style="font-size:15px;">@l.NombreLista</h3>
                            <button type="button" class="dropdown-toggle btn btn-ghost btn-sm"><i class="bi bi-three-dots-vertical"></i></button>
                            
                                      <div class="dropdown-menu">
                                <div class="dd-item" style="display:flex; align-items:center; justify-content:space-between; cursor:default;">
                                    <span>@l.NombreLista</span>

                                    <button type="button" class="rename-toggle" data-target="renombrar-@l.NombreLista" style="border:none;background:none;padding:0;cursor:pointer;color:var(--ink-soft);">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                </div>
                                <form method="post" asp-page-handler="Renombrar" id="renombrar-@l.NombreLista" style="display:none; padding:4px 12px 8px;">
                                    <input type="hidden" name="nombreActual" value="@l.NombreLista" />
                                    <div style="display:flex; gap:6px;">
                                        <input class="field" type="text" name="nombreNuevo" placeholder="Nuevo nombre" maxlength="25">
                                        <button class="btn btn-primary btn-sm" type="submit"><i class="bi bi-check-lg"></i></button>
                                    </div>
                                </form>
                                <a class="dd-item" href="/Lector/MisListas?busqueda=@Model.Busqueda&ver=@l.NombreLista">
                                    <i class="bi bi-journal-bookmark"></i> @(Model.Ver == l.NombreLista ? "Ocultar libros" : "Ver libros")
                                </a>
                                <form method="post" asp-page-handler="Eliminar" class="confirm-delete">
                                    <input type="hidden" name="nombreLista" value="@l.NombreLista" />
                                    <button class="dd-item" type="submit" style="color:var(--stamp-red);"><i class="bi bi-trash"></i> Eliminar</button>
                                </form>
                            </div>
                        </div>


                        <p style="font-size:12px; color:var(--ink-soft);">@l.CantidadLibros libro(s) · Actualizada: @l.UltimaActualizacion.ToShortDateString()</p>

                        @if (Model.Ver == l.NombreLista)
                        {
                            <ul>
                          @foreach (var libro in Model.LibrosDeListaSeleccionada)
                          {
                            <li style="display:flex; justify-content:space-between; align-items:center;">
                              @libro.Titulo
                              <form method="post" asp-page-handler="QuitarLibro" class="confirm-delete" style="display:inline;">
                                <input type="hidden" name="idLibro" value="@libro.IdLibro" />
                                <input type="hidden" name="nombreLista" value="@l.NombreLista" />
                                <button type="submit" class="btn btn-ghost btn-sm"><i class="bi bi-x-circle"></i></button>
                              </form>
                            </li>
                          }
                        </ul>
                        }
         
                    </div>
                }
            </div>

        </main>
    </div>
    <script src="~/js/site.js"></script>
</body>
</html>