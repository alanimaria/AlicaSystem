@page
@model AlicaSystem.Pages.Lector.NuevaListaModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Alica System - Nueva lista</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/alica.css">
</head>
<body>
    <div class="app">
        <partial name="_SidebarLector" view-data="ViewData" />
        <main class="stage" style="padding:32px;">

            <div style="max-width:560px; margin:0 auto;">
                <div class="screen-title" style="text-align:left;">
                    <span class="eyebrow">Lector · Formulario</span>
                    <h1>Nueva lista</h1>
                    <p>Crea una lista personalizada para organizar los libros que te interesan.</p>
                </div>
                <div class="card pad-l">
                    <form method="post">
                        <div class="field-group">
                            <label class="field-label">Nombre de la lista <span class="req">*</span></label>
                            <input class="field" asp-for="NombreLista" maxlength="25" data-maxlen="contador-nombre" placeholder="Ej. Tesis - Referencias">
                            <div class="field-help" id="contador-nombre">0/25</div>
                        </div>
                        <div class="toast-note brass" style="margin-bottom:20px;">
                            Tienes @Model.ListasActuales de 10 listas activas.
                        </div>
                        @if (Model.Mensaje != null)
                        {
                            <p>@Model.Mensaje</p>
                        }
                        <div style="display:flex; gap:12px;">
                            <button class="btn btn-primary" type="submit">Crear lista</button>
                            <a class="btn btn-ghost" href="/Lector/MisListas">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>

        </main>
    </div>
</body>
</html>