@page
@model AlicaSystem.Pages.Lector.DashboardModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alica System - Mi panel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/alica.css">
</head>
<body style="padding:32px;">

    <div class="screen-title">
        <span class="eyebrow">Lector · Menú principal</span>
        <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
            <h1>Hola, @Model.NombreUsuario</h1>
            <span class="badge-role">Lector</span>
        </div>
        <p>Este es tu panel: consulta tus préstamos activos, tus reservas y sigue explorando el catálogo.</p>
    </div>

    <div class="kpis" style="margin-bottom:24px;">
        <div class="stat-card"><div class="label">Préstamos activos</div><div class="value">2 <span style="font-size:14px;color:var(--ink-soft);">/ 3</span></div><div class="foot">1 vence en 3 días</div></div>
        <div class="stat-card"><div class="label">Reservas pendientes</div><div class="value">1</div><div class="foot">Expira en 21 h</div></div>
        <div class="stat-card"><div class="label">Multas pendientes</div><div class="value">RD$ 0</div><div class="foot">Cuenta al día</div></div>
        <div class="stat-card"><div class="label">Listas creadas</div><div class="value">3</div><div class="foot">24 libros guardados</div></div>
    </div>

    <div class="grid-2">
        <div class="card pad-m">
            <div class="section-head"><h2 style="font-size:16px;">Préstamos activos</h2><a style="font-size:12px; color:var(--navy); font-weight:600; cursor:pointer;">Ver todos →</a></div>
            <table>
                <thead><tr><th>Libro</th><th>Vence</th><th>Estado</th></tr></thead>
                <tbody>
                    <tr><td>Cien años de soledad</td><td>18 jul 2026</td><td><span class="stamp ok">Activo</span></td></tr>
                    <tr><td>Estructuras de Datos</td><td>15 jul 2026</td><td><span class="stamp warn">Por vencer</span></td></tr>
                </tbody>
            </table>
        </div>
        <div class="card pad-m">
            <div class="section-head"><h2 style="font-size:16px;">Sigue explorando</h2><a style="font-size:12px; color:var(--navy); font-weight:600; cursor:pointer;">Ir al catálogo →</a></div>
            <div class="grid-2" style="gap:12px;">
                <div class="book-card">
                    <div class="book-cover cover-3"><span class="cat-tag">Ciencia</span>Breve historia<br>del tiempo</div>
                    <div class="book-body"><div class="book-author">S. Hawking</div><span class="stamp ok" style="align-self:flex-start;">Disponible</span></div>
                </div>
                <div class="book-card">
                    <div class="book-cover cover-2"><span class="cat-tag">Novela</span>El nombre<br>del viento</div>
                    <div class="book-body"><div class="book-author">P. Rothfuss</div><span class="stamp danger" style="align-self:flex-start;">Prestado</span></div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>