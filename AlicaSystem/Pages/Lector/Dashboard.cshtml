@page
@model AlicaSystem.Pages.Lector.DashboardModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alica System - Mi panel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/alica.css">
</head>
<body>
    <div class="app">
        <partial name="_SidebarLector" view-data="ViewData" />
        <main class="stage" style="padding:32px;">

    <div class="screen-title">
        <span class="eyebrow">Lector · Menú principal</span>
        <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
            <h1>Hola, @Model.NombreUsuario</h1>
            <span class="badge-role">Lector</span>
        </div>
        <p>Este es tu panel: consulta tus préstamos activos, tus reservas y sigue explorando el catálogo.</p>
    </div>

            <div class="kpis" style="margin-bottom:24px;">
                <div class="stat-card"><div class="label">Préstamos activos</div><div class="value">@Model.PrestamosActivos <span style="font-size:14px;color:var(--ink-soft);">/ 3</span></div></div>
                <div class="stat-card"><div class="label">Reservas pendientes</div><div class="value">@Model.ReservasPendientes</div></div>
                <div class="stat-card"><div class="label">Multas pendientes</div><div class="value">@Model.MultasPendientes</div></div>
                <div class="stat-card"><div class="label">Listas creadas</div><div class="value">@Model.ListasCreadas</div></div>
            </div>

            <div class="grid-2">
                <div class="card pad-m">
                    <div class="section-head">
                        <h2 style="font-size:16px;">Préstamos activos</h2>
                        <a href="/Lector/MisPrestamos" class="link-plain" style="font-size:12px; color:var(--navy); font-weight:600; cursor:pointer;">Ver todos</a>
                    </div>
                    <table>
                        <thead><tr><th>Libro</th><th>Vence</th><th>Estado</th></tr></thead>
                        <tbody>
                            @if (!Model.PrestamosRecientes.Any())
                            {
                                <tr><td colspan="3" style="color:var(--ink-soft);">Sin préstamos activos.</td></tr>
                            }
                            else
                            {
                                @foreach (var p in Model.PrestamosRecientes)
                                {
                                    <tr>
                                        <td>@p.Titulo</td>
                                        <td>@p.FechaDevEsperada.ToString("dd MMM yyyy")</td>
                                        <td><span class="stamp @(p.Estado == "Vencido" ? "danger" : "ok")">@p.Estado</span></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="card pad-m">
                    <div class="section-head">
                        <h2 style="font-size:16px;">Sigue explorando</h2>
                        <a href="/Lector/Catalogo" class="link-plain" style="font-size:12px; color:var(--navy); font-weight:600; cursor:pointer;">Ir al catálogo </a>
                    </div>
                    <div class="grid-2" style="gap:12px;">
                        @if (!Model.LibrosSugeridos.Any())
                        {
                            <p style="color:var(--ink-soft); font-size:13px;">Aún no hay libros disponibles en el catálogo.</p>
                        }
                        else
                        {
                            string[] covers = { "cover-1", "cover-2", "cover-3", "cover-4", "cover-5", "cover-6" };
                            for (int i = 0; i < Model.LibrosSugeridos.Count; i++)
                            {
                                var l = Model.LibrosSugeridos[i];
                                <div class="book-card">
                                    <div class="book-cover @covers[i % covers.Length]"><span class="cat-tag">@l.Categoria</span>@l.Titulo</div>
                                    <div class="book-body"><div class="book-author">@(l.Autores ?? "Autor no registrado")</div><span class="stamp ok" style="align-self:flex-start;">Disponible</span></div>
                                </div>
                            }
                        }
                    </div>
                </div>
                </div>

    </main>
</div>
</body>
</html>