@page
@model AlicaSystem.Pages.Lector.ReservaModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Alica System - Confirmar reserva</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/alica.css">
</head>
<body>
    <div class="app">
        <partial name="_SidebarLector" view-data="ViewData" />
        <main class="stage" style="padding:32px;">

            <div class="screen-title">
                <span class="eyebrow">Lector · Formulario</span>
                <h1>Confirmar reserva</h1>
                <p>Revisa los datos antes de confirmar. Recuerda que las reservas expiran automáticamente.</p>
            </div>

            @if (TempData["Mensaje"] != null)
            {
                <div class="toast-note brass" style="margin-bottom:16px;">@TempData["Mensaje"]</div>
            }

            @if (Model.Libro != null)
            {
                var l = Model.Libro;
                <div class="card pad-l" style="max-width:600px;">
                    <div style="display:flex; gap:14px; align-items:center; margin-bottom:20px;">
                        <div class="book-cover cover-1" style="width:70px; height:70px; flex:none; font-size:11px; padding:8px;">@l.Titulo</div>
                        <div>
                            <div style="font-weight:600; color:var(--navy-deep);">@l.Titulo</div>
                            <div style="font-size:12px; color:var(--ink-soft);">@(l.Autores ?? "Autor no registrado") · @l.CodigoInterno</div>
                        </div>
                    </div>

                    <div class="toast-note" style="margin-bottom:20px;">
                        Solo puedes tener una reserva activa por libro. Si no recoges el ejemplar antes de la fecha límite, la reserva pasará automáticamente a estado <strong>Expirada</strong>.
                    </div>

                    <form method="post">
                        <input type="hidden" name="idLibro" value="@l.IdLibro" />
                        <button class="btn btn-primary" type="submit">Confirmar reserva</button>
                        <a class="btn btn-ghost" href="/Lector/FichaLibro?id=@l.IdLibro">Cancelar</a>
                    </form>
                </div>
            }

        </main>
    </div>
    <script src="~/js/site.js"></script>
</body>
</html>