@page
@model AlicaSystem.Pages.Lector.FichaLibroModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Alica System - Ficha del libro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/alica.css">
</head>
<body>
    <div class="app">
        <partial name="_SidebarLector" view-data="ViewData" />
        <main class="stage" style="padding:32px;">

            @if (Model.Libro == null)
            {
                <div class="empty-state">
                    <h4>Libro no encontrado</h4>
                    <a class="btn btn-ghost btn-sm" href="/Lector/Catalogo">Volver al catálogo</a>
                </div>
            }
            else
            {
                var l = Model.Libro;
                <div class="screen-title">
                    <span class="eyebrow">Lector · Ficha de catálogo</span>
                    <h1>Detalle del libro</h1>
                </div>

                @if (TempData["Mensaje"] != null)
                {
                    <div class="toast-note brass" style="margin-bottom:16px;">@TempData["Mensaje"]</div>
                }

                <div class="grid-2">
                    <div class="card">
                        <div class="book-cover cover-1" style="height:220px;">
                            <span class="cat-tag">@l.Categoria</span>
                            @l.Titulo
                        </div>
                        <div class="pad-m" style="font-size:12px; color:var(--ink-soft); line-height:1.7;">
                            ISBN: @(l.Isbn ?? "N/A")<br>
                            Código interno: @l.CodigoInterno<br>
                            Ubicación: @(l.Ubicacion ?? "No especificada")
                        </div>
                    </div>

                    <div class="card pad-l">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                            <div>
                                <h2 style="font-size:22px;">@l.Titulo</h2>
                                <p style="color:var(--ink-soft); font-size:13px; margin-top:4px;">@(l.Autores ?? "Autor no registrado") · Categoría: @l.Categoria</p>
                            </div>
                            <span class="stamp @(l.CantidadDisponible > 0 ? "ok" : "danger")">@(l.CantidadDisponible > 0 ? "Disponible" : "Prestado")</span>
                        </div>

                        <div class="divider"></div>

                        <div class="grid-3" style="margin-bottom:20px;">
                            <div class="stat-card">
                                <div class="label">Ejemplares totales</div>
                                <div class="value">@l.CantidadTotal</div>
                            </div>
                            <div class="stat-card">
                                <div class="label">Disponibles ahora</div>
                                <div class="value">@l.CantidadDisponible</div>
                            </div>
                            <div class="stat-card">
                                <div class="label">Estado</div>
                                <div class="value" style="font-size:15px;">@l.EstadoLibro</div>
                            </div>
                        </div>

                        <div style="display:flex; gap:10px; flex-wrap:wrap;">
                            @if (l.CantidadDisponible > 0)
                            {
                                <a class="btn btn-primary" href="/Lector/Reserva?idLibro=@l.IdLibro">Reservar este libro</a>
                            }
                            else
                            {
                                <button class="btn btn-primary" disabled>No disponible para reservar</button>
                            }

                            <button type="button" class="dropdown-toggle btn btn-ghost">+ Agregar a una lista</button>
                            <div class="dropdown-menu">
                                @if (!Model.ListasUsuario.Any())
                                {
                                    <span class="dd-item" style="color:var(--ink-soft);">No tienes listas creadas</span>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="AgregarALista">
                                        <input type="hidden" name="idLibro" value="@l.IdLibro" />
                                        @foreach (var nombre in Model.ListasUsuario)
                                        {
                                            <button type="submit" name="nombreLista" value="@nombre" class="dd-item">@nombre</button>
                                        }
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

        </main>
    </div>
    <script src="~/js/site.js"></script>
</body>
</html>