@page
@model AlicaSystem.Pages.Administrador.GestionarCategoriasModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Alica System - Categorías</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/alica.css">
</head>
<body>
    <div class="app">
        <partial name="_SidebarAdministrador" view-data="ViewData" />
        <main class="stage" style="padding:32px;">

            <div class="screen-title">
                <span class="eyebrow">Administrador · Catálogo</span>
                <div><h1>Categorías</h1><p>Clasifica el catálogo por género o área temática.</p></div>
            </div>

            @if (TempData["Mensaje"] != null)
            {
                <p>@TempData["Mensaje"]</p>
            }

            <div class="grid-2" style="grid-template-columns:1.3fr .9fr; align-items:flex-start;">
                <div class="card pad-m">
                    <table>
                        <thead><tr><th>Categoría</th><th class="hide-mobile">Descripción</th><th>Acciones</th></tr></thead>
                        <tbody>
                            @foreach (var c in Model.Categorias)
                            {
                                <tr>
                                    <td>@c.Nombre</td>
                                    <td class="hide-mobile">@c.Descripcion</td>
                                    <td>
                                        <a class="btn btn-ghost btn-sm" href="/Administrador/GestionarCategorias?id=@c.IdCategoria">Editar</a>
                                        <form method="post" asp-page-handler="Eliminar" class="confirm-delete" style="display:inline;">
                                            <input type="hidden" name="id" value="@c.IdCategoria" />
                                            <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="card pad-l">
                    <h3 style="font-size:15px; margin-bottom:16px;">Registrar / editar categoría</h3>
                    <form method="post">
                        <input type="hidden" asp-for="IdCategoria" />
                        <div class="field-group"><label class="field-label">Nombre <span class="req">*</span></label><input class="field" asp-for="Nombre" placeholder="Ej. Tecnología"></div>
                        <div class="field-group"><label class="field-label">Descripción</label><textarea class="field" rows="4" asp-for="Descripcion" placeholder="Descripción breve…"></textarea></div>
                        <button class="btn btn-primary btn-block" type="submit">Guardar categoría</button>
                    </form>
                </div>
            </div>

        </main>
    </div>
</body>
</html>