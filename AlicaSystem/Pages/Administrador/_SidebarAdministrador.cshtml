@{
    string activo = ViewData["Activo"] as string ?? "";
}
<aside class="sidebar">
    <div class="brand">
        <img src="~/images/logo.png" alt="Alica System" style="width:40px;height:40px;object-fit:contain;">
        <div class="brand-text"><div class="name">Alica System</div><div class="sub">Sistema Bibliotecario</div></div>
    </div>
    <nav class="nav-group">
        <div class="nav-group-label">Administrador</div>
        <a class="nav-item @(activo == "GestionarLibros" ? "active" : "")" href="/Administrador/GestionarLibros"><span class="dot"></span>Libros</a>
        <a class="nav-item @(activo == "GestionarCategorias" ? "active" : "")" href="/Administrador/GestionarCategorias"><span class="dot"></span>Categorías</a>
        <a class="nav-item @(activo == "GestionarAutores" ? "active" : "")" href="/Administrador/GestionarAutores"><span class="dot"></span>Autores</a>
        <a class="nav-item @(activo == "GestionarPersonas" ? "active" : "")" href="/Administrador/GestionarPersonas"><span class="dot"></span>Usuarios</a>
        <a class="nav-item @(activo == "GestionarEmpleados" ? "active" : "")" href="/Administrador/GestionarEmpleados"><span class="dot"></span>Empleados</a>
        <a class="nav-item @(activo == "GestionarRoles" ? "active" : "")" href="/Administrador/GestionarRoles"><span class="dot"></span>Roles</a>
    </nav>
    <div class="sidebar-foot">Alica System · Universidad · Desarrollo Web II</div>
</aside>