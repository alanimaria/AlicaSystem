@page
@model AlicaSystem.Pages.Administrador.DashboardModel
@{
    Layout = null;
    ViewData["Activo"] = "Dashboard";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alica System - Panel administrador</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/alica.css">
</head>
<body>
    <div class="app">
        <partial name="_SidebarAdministrador" />

        <main class="stage" style="padding:32px 40px;">
            <div class="screen-title">
                <span class="eyebrow">Administrador · Menú principal</span>
                <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
                    <h1>Panel general del sistema</h1>
                    <span class="badge-role">@Model.NombreUsuario</span>
                </div>
                <p>Gestiona el catálogo, las personas y la configuración del sistema.</p>
            </div>

            <div class="grid-4">
                <div class="card pad-m" style="cursor:pointer;" onclick="location.href='/Administrador/GestionarLibros'">
                    <div class="quick-icon"><i class="bi bi-journal-bookmark" style="font-size:20px;"></i></div>
                    <div style="font-weight:600; color:var(--navy-deep); margin-top:8px;">Libros</div>
                    <div style="font-size:12px; color:var(--ink-soft); margin-top:2px;">Catálogo e inventario</div>
                </div>
                <div class="card pad-m" style="cursor:pointer;" onclick="location.href='/Administrador/GestionarCategorias'">
                    <div class="quick-icon"><i class="bi bi-tags" style="font-size:20px;"></i></div>
                    <div style="font-weight:600; color:var(--navy-deep); margin-top:8px;">Categorías</div>
                    <div style="font-size:12px; color:var(--ink-soft); margin-top:2px;">Organizar el catálogo</div>
                </div>
                <div class="card pad-m" style="cursor:pointer;" onclick="location.href='/Administrador/GestionarAutores'">
                    <div class="quick-icon"><i class="bi bi-person-badge" style="font-size:20px;"></i></div>
                    <div style="font-weight:600; color:var(--navy-deep); margin-top:8px;">Autores</div>
                    <div style="font-size:12px; color:var(--ink-soft); margin-top:2px;">Gestionar autores registrados</div>
                </div>
                <div class="card pad-m" style="cursor:pointer;" onclick="location.href='/Administrador/GestionarPersonas'">
                    <div class="quick-icon"><i class="bi bi-people" style="font-size:20px;"></i></div>
                    <div style="font-weight:600; color:var(--navy-deep); margin-top:8px;">Usuarios</div>
                    <div style="font-size:12px; color:var(--ink-soft); margin-top:2px;">Gestionar lectores</div>
                </div>
                <div class="card pad-m" style="cursor:pointer;" onclick="location.href='/Administrador/GestionarEmpleados'">
                    <div class="quick-icon"><i class="bi bi-person-workspace" style="font-size:20px;"></i></div>
                    <div style="font-weight:600; color:var(--navy-deep); margin-top:8px;">Empleados</div>
                    <div style="font-size:12px; color:var(--ink-soft); margin-top:2px;">Bibliotecarios y administradores</div>
                </div>
                <div class="card pad-m" style="cursor:pointer;" onclick="location.href='/Administrador/GestionarRoles'">
                    <div class="quick-icon"><i class="bi bi-shield-lock" style="font-size:20px;"></i></div>
                    <div style="font-weight:600; color:var(--navy-deep); margin-top:8px;">Roles</div>
                    <div style="font-size:12px; color:var(--ink-soft); margin-top:2px;">Permisos del sistema</div>
                </div>
            </div>
        </main>
    </div>
</body>
</html>