@page
@model AlicaSystem.Pages.Bibliotecario.DashboardModel
@{
    Layout = null;
    ViewData["Activo"] = "Dashboard";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alica System - Panel bibliotecario</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/alica.css">
</head>
<body>
    <div class="app">
        <partial name="_SidebarBibliotecario" />

        <main class="stage" style="padding:32px 40px;">
            <div class="screen-title">
                <span class="eyebrow">Bibliotecario · Menú principal</span>
                <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
                    <h1>Panel operativo</h1>
                    <span class="badge-role">@Model.NombreUsuario</span>
                </div>
                <p>Gestiona préstamos, devoluciones, reservas y multas del día.</p>
            </div>

            <div class="grid-4" style="margin-bottom:22px;">
                <div class="card pad-m" style="cursor:pointer;" onclick="location.href='/Bibliotecario/RegistrarPrestamo'">
                    <div class="quick-icon"><i class="bi bi-journal-plus" style="font-size:20px;"></i></div>
                    <div style="font-weight:600; color:var(--navy-deep); margin-top:8px;">Registrar préstamo</div>
                    <div style="font-size:12px; color:var(--ink-soft); margin-top:2px;">Entregar libro a un lector</div>
                </div>
                <div class="card pad-m" style="cursor:pointer;">
                    <div class="quick-icon clay"><i class="bi bi-arrow-return-left" style="font-size:20px;"></i></div>
                    <div style="font-weight:600; color:var(--navy-deep); margin-top:8px;">Registrar devolución</div>
                    <div style="font-size:12px; color:var(--ink-soft); margin-top:2px;">Cerrar un préstamo activo</div>
                </div>
                <div class="card pad-m" style="cursor:pointer;" onclick="location.href='/Bibliotecario/ReservasPendientes'">
                    <div class="quick-icon"><i class="bi bi-bookmark-star" style="font-size:20px;"></i></div>
                    <div style="font-weight:600; color:var(--navy-deep); margin-top:8px;">Reservas pendientes</div>
                    <div style="font-size:12px; color:var(--ink-soft); margin-top:2px;">@Model.ReservasPendientes esperando ser recogidas</div>
                </div>
                <div class="card pad-m" style="cursor:pointer;" onclick="location.href='/Bibliotecario/Multas'">
                    <div class="quick-icon" style="background:var(--stamp-red-tint); color:var(--stamp-red);"><i class="bi bi-exclamation-triangle" style="font-size:20px;"></i></div>
                    <div style="font-weight:600; color:var(--navy-deep); margin-top:8px;">Multas pendientes</div>
                    <div style="font-size:12px; color:var(--ink-soft); margin-top:2px;">@Model.MultasPendientes usuarios con saldo</div>
                </div>
            </div>

            <div class="card pad-m" style="margin-bottom:22px; display:flex; align-items:center; gap:12px;">
                <i class="bi bi-journal-check" style="font-size:22px; color:var(--navy-deep);"></i>
                <div>
                    <div style="font-size:12px; color:var(--ink-soft); text-transform:uppercase; letter-spacing:.05em;">Préstamos activos</div>
                    <div style="font-size:32px; font-weight:700; color:var(--navy-deep);">@Model.PrestamosActivos</div>
                </div>
            </div>

            <div class="card pad-m">
                <div class="section-head"><h2 style="font-size:16px;">Actividad reciente</h2></div>
                <table>
                    <thead><tr><th>Fecha</th><th>Usuario</th><th>Libro</th><th>Acción</th></tr></thead>
                    <tbody>
                        @if (Model.ActividadReciente.Count == 0)
                        {
                            <tr>
                                <td colspan="4" style="text-align:center; color:var(--ink-soft); padding:24px 0;">
                                    Todavía no hay actividad registrada
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.ActividadReciente)
                            {
                                <tr>
                                    <td class="hide-mobile" style="font-family:var(--font-mono);">@item.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Usuario</td>
                                    <td>@item.Libro</td>
                                    <td>
                                        @if (item.Accion == "Prestamo")
                                        {
                                            <span class="stamp ok">Préstamo</span>
                                        }
                                        else if (item.Accion == "Devolucion")
                                        {
                                            <span class="stamp info">Devolución</span>
                                        }
                                        else
                                        {
                                            <span class="stamp warn">Reserva</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</body>
</html>