@page
@model AlicaSystem.Pages.Bibliotecario.GestionarMultasModel
@{
    Layout = null;
    ViewData["Activo"] = "Multas";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alica System - Multas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/alica.css">
</head>
<body>
    <div class="app">
        <partial name="_SidebarBibliotecario" />

        <main class="stage" style="padding:32px 40px;">
            <div class="screen-title">
                <span class="eyebrow">Bibliotecario · Gestión</span>
                <h1>Multas pendientes</h1>
                <p>Usuarios con saldo pendiente por pagar.</p>
            </div>

            @Html.AntiForgeryToken()

            <div class="card pad-m">
                <table>
                    <thead>
                        <tr>
                            <th>Usuario</th>
                            <th>Monto</th>
                            <th>Generada</th>
                            <th class="hide-mobile">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="tablaMultas">
                        @if (Model.Multas.Count == 0)
                        {
                            <tr><td colspan="4">No hay multas pendientes ahora mismo.</td></tr>
                        }
                        @foreach (var m in Model.Multas)
                        {
                            <tr id="fila-@m.IdMulta">
                                <td>@m.Usuario</td>
                                <td>RD$@m.Monto.ToString("N2")</td>
                                <td>@m.FechaGeneracion.ToString("dd MMM yyyy")</td>
                                <td class="hide-mobile">
                                    <button type="button" class="btn btn-brass btn-sm" onclick="marcarPagada(@m.IdMulta)">Marcar pagada</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <script>
            async function marcarPagada(idMulta) {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                const body = new URLSearchParams();
                body.append('idMulta', idMulta);
                body.append('__RequestVerificationToken', token);

                const resp = await fetch('?handler=ActualizarEstado', { method: 'POST', body: body });
                const data = await resp.json();

                if (data.exito) {
                    document.getElementById('fila-' + idMulta).remove();
                } else {
                    alert('No se pudo actualizar la multa. Puede que ya no este pendiente.');
                }
            }
    </script>
</body>
</html>