@page
@model AlicaSystem.Pages.RecuperarModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Alica System - Recuperar contraseña</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/alica.css">

</head>
<body>

    <div style="max-width:460px; margin:40px auto;">
        <div class="card pad-l">
            <div class="screen-title" style="margin-bottom:20px;">
                <span class="eyebrow">Acceso · Recuperación</span>
                <h1 style="font-size:21px;">Recuperar contraseña</h1>
                <p>Ingresa tu correo y tu nueva contraseña.</p>
            </div>

            <form method="post">
                <div class="field-group">
                    <label class="field-label">Correo electrónico <span class="req">*</span></label>
                    <input class="field" type="email" asp-for="Email" placeholder="nombre.apellido@institucion.edu">
                </div>
                <div class="field-group">
                    <label class="field-label">Nueva contraseña <span class="req">*</span></label>
                    <div style="position:relative;">
                        <input class="field" id="campoNuevaPassword" style="padding-right:36px;" type="password" asp-for="NuevaPassword" placeholder="••••••••••">
                        <button type="button" class="toggle-password" data-target="campoNuevaPassword" style="position:absolute; right:10px; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; color:var(--ink-soft); padding:0;">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>
                <div class="field-group">
                    <label class="field-label">Confirmar contraseña <span class="req">*</span></label>
                    <div style="position:relative;">
                        <input class="field" id="campoConfirmarPassword" style="padding-right:36px;" type="password" asp-for="ConfirmarPassword" placeholder="••••••••••">
                        <button type="button" class="toggle-password" data-target="campoConfirmarPassword" style="position:absolute; right:10px; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; color:var(--ink-soft); padding:0;">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>
                <button class="btn btn-primary btn-block" type="submit">Actualizar contraseña</button>
            </form>

            @if (Model.Mensaje != null)
            {
                <p style="margin-top:16px; text-align:center;">@Model.Mensaje</p>
            }

            <p style="text-align:center; font-size:12.5px; color:var(--ink-soft); margin-top:18px;">
                <a style="color:var(--navy); font-weight:600;" href="/Login">← Volver a iniciar sesión</a>
            </p>
        </div>
    </div>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <script src="~/js/site.js"></script>
</body>
</html>