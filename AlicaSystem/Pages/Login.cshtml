@page
@model AlicaSystem.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alica System - Iniciar sesión</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/alica.css">
</head>
<body>

    <div class="two-col-auth" style="min-height:100vh;">
        <div class="auth-left">
            <div>
                <div class="brand" style="border:none;padding:0;">
                    <img src="~/images/logo.png" alt="Alica System" style="width:64px; height:auto;">
                    <div class="brand-text"><div class="name" style="color:#F7F5F1;">Alica System</div><div class="sub">Universidad</div></div>
                </div>
            </div>
            <div class="auth-quote">
                "Un catálogo bien llevado no guarda libros: guarda el camino de vuelta a ellos."
                <div class="who">Portal de biblioteca - Universidad</div>
            </div>
            <div style="font-size:11px; color:#9A9284;">© 2026 Universidad · Sistema de Gestión Bibliotecaria Universitaria</div>
        </div>

        <div class="auth-right">
            <h2 style="font-size:22px;margin-bottom:6px;">Bienvenido de nuevo</h2>
            <p style="color:var(--ink-soft); font-size:13px; margin-bottom:26px;">Ingresa con tu correo institucional para continuar.</p>

            <form method="post">
                <div class="field-group">
                    <label class="field-label">Correo electrónico <span class="req">*</span></label>
                    <input class="field" type="email" asp-for="Email" placeholder="nombre.apellido@institucion.edu">
                </div>
                <div class="field-group">
                    <label class="field-label">Contraseña <span class="req">*</span></label>
                    <div style="position:relative;">
                        <i class="bi bi-lock" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--ink-soft);"></i>
                        <input class="field" id="campoClave" style="padding-left:36px; padding-right:36px;" type="password" asp-for="Clave" placeholder="••••••••••">
                        <button type="button" class="toggle-password" data-target="campoClave" style="position:absolute; right:10px; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; color:var(--ink-soft); padding:0;">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>
                <button class="btn btn-primary btn-block" type="submit">Ingresar</button>
            </form>
            <p style="text-align:center; font-size:12.5px; margin-top:14px;">
                <a style="color:var(--navy); font-weight:600;" href="/Recuperar">¿Olvidaste tu contraseña?</a>
            </p>
            @if (Model.Mensaje != null)
            {
                <p style="margin-top:16px; text-align:center;">@Model.Mensaje</p>
            }
        </div>
    </div>
    <script src="~/js/site.js"></script>
</body>
</html>